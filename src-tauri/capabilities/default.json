{
  "identifier": "default",
  "description": "Default capabilities for Lector TBO (all platforms incl. Android)",
  "platforms": [
    "linux",
    "macOS",
    "windows",
    "android",
    "iOS"
  ],
  "windows": [
    "main",
    "reader"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/**",
        "$APPDATA/**",
        "$CACHE/**",
        "$RESOURCE/**",
        "/storage/emulated/0/**",
        "/sdcard/**",
        "/"
      ]
    }
  ]
}